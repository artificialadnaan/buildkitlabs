# BuildKit Labs Website Environment Variables
# Copy this file to .env.local and update values for your environment

# Email configuration for contact forms
NEXT_PUBLIC_CONTACT_EMAIL=hello@buildkitlabs.com

# Optional: If using a mail service (SendGrid, Mailgun, etc.)
# MAIL_SERVICE_API_KEY=your_api_key_here
# MAIL_SERVICE_FROM_EMAIL=noreply@buildkitlabs.com

# Optional: Calendly embed (for scheduling page)
# NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/yourname

# Site configuration
NEXT_PUBLIC_SITE_URL=https://buildkitlabs.com
NEXT_PUBLIC_SITE_NAME=BuildKit Labs
